APP_ENV=production
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://customer_service:REPLACE_DB_PASSWORD@postgres:5432/customer_service
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379/0
AUTH_ENABLED=true
AUTH_JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
AUTH_COOKIE_SECURE=true
AUTH_BOOTSTRAP_TENANT_NAME=生产租户
AUTH_BOOTSTRAP_ADMIN_EMAIL=REPLACE_ADMIN_EMAIL
AUTH_BOOTSTRAP_ADMIN_PASSWORD=REPLACE_STRONG_ADMIN_PASSWORD
AUTH_BOOTSTRAP_ADMIN_NAME=系统管理员
AI_MODEL_PROVIDER=openai-compatible
AI_MODEL_BASE_URL=https://api.deepseek.com
AI_MODEL_API_KEY=REPLACE_LLM_API_KEY
AI_MODEL_NAME=deepseek-chat
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=REPLACE_DASHSCOPE_API_KEY
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
VECTOR_STORE_PROVIDER=pgvector
PGVECTOR_DIMENSIONS=1024
RERANK_PROVIDER=qwen
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
RERANK_API_KEY=REPLACE_DASHSCOPE_API_KEY
RERANK_MODEL=qwen3-rerank
OMS_PROVIDER=http
OMS_BASE_URL=https://REPLACE_REAL_OMS_HOST
OMS_API_KEY=REPLACE_OMS_API_KEY
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_GRAFANA_PASSWORD
