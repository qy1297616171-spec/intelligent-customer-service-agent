{
  "title": "电商智能客服运行概览",
  "uid": "customer-service-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries", "title": "API QPS", "id": 1,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(customer_service_http_requests_total[1m]))", "legendFormat": "QPS"}]
    },
    {
      "type": "timeseries", "title": "P95 响应时间", "id": 2,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(customer_service_http_request_duration_seconds_bucket[5m])))", "legendFormat": "P95"}]
    },
    {
      "type": "timeseries", "title": "HTTP 错误率", "id": 3,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [{"expr": "sum(rate(customer_service_http_requests_total{status=~\"4..|5..\"}[5m])) / clamp_min(sum(rate(customer_service_http_requests_total[5m])), 0.001)", "legendFormat": "错误率"}]
    }
  ]
}
