APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/customer_service.db
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
LOGIN_RATE_LIMIT_PER_MINUTE=10

# 本地演示账号；生产环境必须替换全部凭据并启用 HTTPS Cookie。
AUTH_ENABLED=true
AUTH_JWT_SECRET=local-development-secret-change-before-production-2026
AUTH_ACCESS_TOKEN_MINUTES=480
AUTH_COOKIE_SECURE=false
AUTH_BOOTSTRAP_TENANT_NAME=星选商城
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
AUTH_BOOTSTRAP_ADMIN_NAME=系统管理员

FEATURE_KNOWLEDGE=true
FEATURE_CONVERSATION=true
FEATURE_COMMERCE=true
FEATURE_HANDOFF=true
FEATURE_ANALYTICS=true
FEATURE_CUSTOMER=true
FEATURE_AUTH=true
FEATURE_AUDIT=true

AI_MIN_EVIDENCE_SCORE=0.18
AI_CACHE_TTL_SECONDS=300
# mock | openai-compatible
AI_MODEL_PROVIDER=mock
AI_MODEL_BASE_URL=https://api.deepseek.com
AI_MODEL_API_KEY=
AI_MODEL_NAME=deepseek-v4-flash
AI_MODEL_TIMEOUT_SECONDS=12
AI_MODEL_TEMPERATURE=0
AI_MODEL_MAX_TOKENS=600
AI_MODEL_FALLBACK_ENABLED=true

EMBEDDING_PROVIDER=hash
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=256
EMBEDDING_TIMEOUT_SECONDS=10
RETRIEVAL_VECTOR_WEIGHT=0.55
RETRIEVAL_KEYWORD_WEIGHT=0.45
VECTOR_STORE_PROVIDER=auto
PGVECTOR_DIMENSIONS=256

# heuristic | qwen
RERANK_PROVIDER=heuristic
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
RERANK_API_KEY=
RERANK_MODEL=qwen3-rerank
RERANK_TIMEOUT_SECONDS=8
RERANK_CANDIDATE_LIMIT=20
RERANK_TOP_N=5

# memory | http；Docker Compose 默认使用独立 mock-oms 服务。
OMS_PROVIDER=memory
OMS_BASE_URL=http://mock-oms:8090
OMS_API_KEY=
OMS_TIMEOUT_SECONDS=3

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana
